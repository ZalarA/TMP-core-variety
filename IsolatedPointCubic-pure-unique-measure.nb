Cell[CellGroupData[{
Cell["\<\
Unique 9-atomic representing measure for the TMP on the nodal cubic \
(y^2=x^2(x-1)) in the pure case. \
\>", "Title",
 CellChangeTimes->{{3.784837118837334*^9, 3.784837133465056*^9}, {
