   3.9876527574263687`*^9}},ExpressionUUID->"5f391247-93e1-4047-8e57-\
47d0e433c412"],

Cell[CellGroupData[{

Cell["\<\
The corresponding univariate Hankel matrix has the basis \
T^{-3},T^{-2},T^{-1},1,T,...,T^6.\
\>", "Section",
 CellChangeTimes->{{3.9875956434420357`*^9, 3.987595649171936*^9}, {
  3.9875957067420845`*^9, 3.987595760931566*^9}, {3.987636231358671*^9, 
