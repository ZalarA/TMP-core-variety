Cell[CellGroupData[{

Cell["\<\
The atoms are 5 and i,-i for i = 1, 2, 3, 4. We manipulate the first entry, \
i.e., Mom0[[1,1]] so that the measure of a new sequence will be unique.\
\>", "Section",
 CellChangeTimes->{{3.9876529495177097`*^9, 3.9876529898296967`*^9}, {
  3.9876532203782597`*^9, 3.987653234520647*^9}, {3.987653290213793*^9, 
  3.9876532907537956`*^9}},ExpressionUUID->"e9e99652-a717-8245-812d-\
7d10d8f16b9e"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", 
    RowBox[{
    "v", ",", "momentMatrix", ",", "Mom0", ",", "Mom", ",", "t", ",", "d", ",",
      "p", ",", "disc", ",", "dSols", ",", "results"}], "]"}], ";"}], 
  "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{"Your", " ", "definitions"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"v", "[", "x_", "]"}], ":=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"x", "^", "k"}], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", 
       RowBox[{"-", "3"}], ",", "6"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"momentMatrix", "[", "x_", "]"}], ":=", 
    RowBox[{"Outer", "[", 
     RowBox[{"Times", ",", 
      RowBox[{"v", "[", "x", "]"}], ",", 
      RowBox[{"v", "[", "x", "]"}]}], "]"}]}], ";"}], "\n", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "Build", " ", "the", " ", "numeric", " ", "moment", " ", "matrix", " ", 
    "sum", " ", 
    RowBox[{"(", 
     RowBox[{"same", " ", "structure", " ", "as", " ", "yours"}], ")"}]}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Mom0", "=", 
    RowBox[{"Sum", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"momentMatrix", "[", "i", "]"}], "+", 
       RowBox[{"momentMatrix", "[", 
        RowBox[{"-", "i"}], "]"}], "+", 
       RowBox[{"momentMatrix", "[", "5", "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", "4"}], "}"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Inject", " ", "symbolic", " ", "entries"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"Mom", "=", "Mom0"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Mom", "[", 
    RowBox[{"[", 
     RowBox[{"1", ",", "1"}], "]"}], "]"}], "=", 
   RowBox[{"d", "-", "t"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Mom", "[", 
     RowBox[{"[", 
      RowBox[{"10", ",", "10"}], "]"}], "]"}], "=", "t"}], ";"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Determinant", " ", "as", " ", "polynomial", " ", "in", " ", "t"}],
    "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"p", "=", 
    RowBox[{"Collect", "[", 
     RowBox[{
      RowBox[{"Expand", "[", 
       RowBox[{"Det", "[", "Mom", "]"}], "]"}], ",", "t"}], "]"}]}], ";"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Sanity", " ", 
    RowBox[{"check", ":", 
     RowBox[{
     "confirm", " ", "it", " ", "is", " ", "quadratic", " ", "in", " ", 
      "t"}]}]}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Exponent", "[", 
       RowBox[{"p", ",", "t"}], "]"}], "=!=", "2"}], ",", 
     RowBox[{
      RowBox[{"Print", "[", 
       RowBox[{"\"\<Warning: Det[Mom] is not quadratic in t. Degree = \>\"", ",", 
        RowBox[{"Exponent", "[", 
         RowBox[{"p", ",", "t"}], "]"}]}], "]"}], ";"}]}], "]"}], ";"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Condition", " ", "for", " ", "a", " ", "single", " ", 
    RowBox[{"(", "double", ")"}], " ", "root", " ", "in", " ", "t"}], 
   "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"disc", "=", 
    RowBox[{"Factor", "[", 
     RowBox[{"Discriminant", "[", 
      RowBox[{"p", ",", "t"}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Solve", " ", "discriminant"}], "=", 
    RowBox[{"0", " ", "for", " ", "d"}]}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"dSols", "=", 
    RowBox[{"Solve", "[", 
     RowBox[{
      RowBox[{"disc", "==", "0"}], ",", "d"}], "]"}]}], ";"}], "\n", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"For", " ", "each", " ", "d"}], ",", 
    RowBox[{
     RowBox[{"compute", " ", "the", " ", "corresponding", " ", "double"}], "-", 
     RowBox[{"root", " ", "t", " ", "and", " ", "d"}], "-", "t"}]}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"results", "=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"With", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"d0", "=", 
          RowBox[{"d", "/.", " ", "sol"}]}], "}"}], ",", 
        RowBox[{"Module", "[", 
         RowBox[{
          RowBox[{"{", "t0", "}"}], ",", 
          RowBox[{
           RowBox[{"t0", "=", 
            RowBox[{"t", "/.", " ", 
             RowBox[{"First", "@", 
              RowBox[{"Solve", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"p", "/.", " ", 
                   RowBox[{"d", "->", "d0"}]}], ")"}], "==", "0"}], ",", 
                "t"}], "]"}]}]}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"<|", 
            RowBox[{
             RowBox[{"\"\<d\>\"", "->", "d0"}], ",", 
             RowBox[{"\"\<t\>\"", "->", 
              RowBox[{"FullSimplify", "[", "t0", "]"}]}], ",", 
             RowBox[{"\"\<dMinusT\>\"", "->", 
              RowBox[{"FullSimplify", "[", 
               RowBox[{"d0", "-", "t0"}], "]"}]}]}], "|>"}]}]}], "]"}]}], 
       "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"sol", ",", "dSols"}], "}"}]}], "]"}]}], ";"}], "\n", 
  "\n"}], "\n", "results"}], "Input",
 CellChangeTimes->{{3.9876532366129932`*^9, 3.9876532512838917`*^9}},
 CellLabel->"In[30]:=",ExpressionUUID->"2dfc7496-b4bf-134c-9f32-3d71478536d7"],

