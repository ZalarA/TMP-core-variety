Cell[CellGroupData[{

Cell["Compute coefficients tmin,tmax,E.", "Section",
 CellChangeTimes->{{3.987654535383524*^9, 
  3.9876545477653294`*^9}},ExpressionUUID->"a9d68210-a70e-0048-9617-\
7d93acd0eb09"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"tmin", "=", 
  RowBox[{
   RowBox[{"Mom0", "[", 
    RowBox[{"[", 
     RowBox[{"10", ",", 
      RowBox[{"2", ";;", "9"}]}], "]"}], "]"}], ".", 
   RowBox[{"Inverse", "[", 
    RowBox[{"Mom0", "[", 
     RowBox[{"[", 
      RowBox[{
       RowBox[{"2", ";;", "9"}], ",", 
       RowBox[{"2", ";;", "9"}]}], "]"}], "]"}], "]"}], ".", 
   RowBox[{"Mom0", "[", 
    RowBox[{"[", 
     RowBox[{
      RowBox[{"2", ";;", "9"}], ",", "10"}], "]"}], "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{"tmax", "=", 
  RowBox[{
   RowBox[{"Mom0", "[", 
    RowBox[{"[", 
     RowBox[{"1", ",", "1"}], "]"}], "]"}], "-", 
   RowBox[{
    RowBox[{"Mom0", "[", 
     RowBox[{"[", 
      RowBox[{"1", ",", 
       RowBox[{"2", ";;", "9"}]}], "]"}], "]"}], ".", 
    RowBox[{"Inverse", "[", 
     RowBox[{"Mom0", "[", 
      RowBox[{"[", 
