 RowBox[{
  RowBox[{"v", "[", "t_", "]"}], ":=", 
  RowBox[{"Table", "[", 
   RowBox[{
    RowBox[{"t", "^", "k"}], ",", 
    RowBox[{"{", 
     RowBox[{"k", ",", 
      RowBox[{"-", "3"}], ",", "6"}], "}"}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"momentMatrix", "[", "t_", "]"}], ":=", 
  RowBox[{"Outer", "[", 
   RowBox[{"Times", ",", 
    RowBox[{"v", "[", "t", "]"}], ",", 
    RowBox[{"v", "[", "t", "]"}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"momentMatrix", "[", "t", "]"}], "//", "MatrixForm"}]}], "Input",
 CellLabel->"In[27]:=",ExpressionUUID->"d7fe46dd-5d04-3f4d-aaf6-2068d89619e4"],

