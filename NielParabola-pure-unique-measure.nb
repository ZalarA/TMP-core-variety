Notebook[{

Cell[CellGroupData[{
Cell["\<\
Example of a sequence \[Beta]^{(9)} with a unique 9-atomic measure supported \
on the curve y^2-x^3.\
\>", "Title",
 CellChangeTimes->{{3.784837118837334*^9, 3.784837133465056*^9}, {
   3.90060306861498*^9, 3.9006031537261477`*^9}, {3.9266047539325275`*^9, 
   3.926604789254099*^9}, 3.926605826933323*^9, 3.9865144729000206`*^9, {
   3.9865145306689053`*^9, 
   3.9865145319296665`*^9}},ExpressionUUID->"5f391247-93e1-4047-8e57-\
47d0e433c412"],

Cell[TextData[StyleBox["We  do  reverse  engineering  and  generate  a  \
univariate  sequence  \[Gamma] = (\[Gamma]_i) _ {i <= 18}  of  degree  18, \
such  that  the  restriction  of  the  Hankel  matrix  A_\[Gamma]  to  \
columns  and  rows  indexed  by  1, X^2, X^3, ..., X^9  is  positive  \
definite, but  the  restriction  to  columns  and  rows  X, X^2, ..., X^9  is \
recursively  generate  and singular, i.e ., column  X^9  is  in  the  span  \
of  the  previous  ones. Then  we  generate  a  sequence  \[Beta] = { \
\[Beta]_ {i, j}} _ {i + j <= 6}  by  \[Beta]_ {i, j} = \[Gamma]_ {2 i + 3 j} \
. By  the  solution  to  the  TMP  on  Y^2 - X^3  (Corollary  4.3  in  A . \
Zalar, The  truncated  Hamburger  moment  problems  with  gaps  in  the  \
index  set, Integ . Equ . Oper . Theory  93  (2021)), \[Beta]  will have  a  \
(y^2 - x^3) - supported  representing  measure and this will be the only rm \
for \[Beta], since the matrix A_\[Gamma] has only one psd completion, i.e., \
there is a unique choice of \[Gamma]_1.", "Section"]], "Subsection",
 CellChangeTimes->{{3.9267383320280704`*^9, 3.926738417168827*^9}, {
  3.926738513270645*^9, 
  3.926738530603647*^9}},ExpressionUUID->"ff3d0732-edd6-6144-b36e-\
08bfc89f7b30"],

Cell[CellGroupData[{

Cell["\<\
First we generate a univariate sequence \[Gamma] with 9  atoms \
0,1,1/2,1/3,...,1/8.\
\>", "Subsection",
 CellChangeTimes->{{3.900603849625372*^9, 3.9006038992824717`*^9}, {
  3.926738313415367*^9, 3.9267383140511856`*^9}, {3.9267385863996162`*^9, 
  3.9267385865233116`*^9}},ExpressionUUID->"a6991485-cdf9-4e7d-a1f1-\
ccbd257586b0"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"H", "[", 
    RowBox[{
    "\[Gamma]0_", ",", "\[Gamma]1_", ",", "\[Gamma]2_", ",", "\[Gamma]3_", 
     ",", "\[Gamma]4_", ",", "\[Gamma]5_", ",", "\[Gamma]6_", ",", 
     "\[Gamma]7_", ",", "\[Gamma]8_", ",", "\[Gamma]9_", ",", "\[Gamma]10_", 
     ",", "\[Gamma]11_", ",", "\[Gamma]12_", ",", "\[Gamma]13_", ",", 
     "\[Gamma]14_", ",", "\[Gamma]15_", ",", "\[Gamma]16_", ",", 
     "\[Gamma]17_", ",", "\[Gamma]18_"}], "]"}], "=", 
   RowBox[{"HankelMatrix", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "\[Gamma]0", ",", "\[Gamma]1", ",", "\[Gamma]2", ",", "\[Gamma]3", ",", 
       "\[Gamma]4", ",", "\[Gamma]5", ",", "\[Gamma]6", ",", "\[Gamma]7", ",",
        "\[Gamma]8", ",", "\[Gamma]9"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
      "\[Gamma]9", ",", "\[Gamma]10", ",", "\[Gamma]11", ",", "\[Gamma]12", 
       ",", "\[Gamma]13", ",", "\[Gamma]14", ",", "\[Gamma]15", ",", 
       "\[Gamma]16", ",", "\[Gamma]17", ",", "\[Gamma]18"}], "}"}]}], "]"}]}],
   ";"}]], "Input",
 CellChangeTimes->{{3.900506346013999*^9, 3.900506551228964*^9}, 
   3.900510462563928*^9},
 CellLabel->"In[1]:=",ExpressionUUID->"f2f2dff2-e2f4-4c76-b6cf-ea93348f1538"],

