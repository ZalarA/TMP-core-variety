Cell[CellGroupData[{

Cell["\<\
The atoms are i,-i for i =  2, 3, 4,5 and unknown w to be determined. We \
manipulate the south-easth entry, i.e., Mom0[[10,10]] so that the measure of \
a new sequence will be unique. We need to insure that the matrix on all but \
the second row and column is positive definite, while the one without the \
first row and column is positive semidefinite and singular. We are searching \
for w and u.\
\>", "Section",
 CellChangeTimes->{{3.9876529495177097`*^9, 3.9876529898296967`*^9}, {
  3.9876532203782597`*^9, 3.987653234520647*^9}, {3.987653290213793*^9, 
  3.9876532907537956`*^9}, {3.9878173171417217`*^9, 3.987817362794319*^9}, {
  3.987817445350155*^9, 
  3.9878174928673134`*^9}},ExpressionUUID->"e9e99652-a717-8245-812d-\
7d10d8f16b9e"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", "w", "]"}], ";", 
  RowBox[{"Clear", "[", "u", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Mom0", "=", 
   RowBox[{
    RowBox[{"Sum", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"MomMat", "[", "i", "]"}], "+", 
       RowBox[{"MomMat", "[", 
        RowBox[{"-", "i"}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "2", ",", "5"}], "}"}]}], "]"}], "+", 
    RowBox[{"MomMat", "[", "w", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Mom0", "[", 
    RowBox[{"[", 
     RowBox[{"10", ",", "10"}], "]"}], "]"}], "=", "u"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"MatrixForm", "[", "Mom0", "]"}], "\[IndentingNewLine]", 
 RowBox[{"FindInstance", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"Det", "[", 
      RowBox[{"Matrix", "[", 
       RowBox[{"[", 
        RowBox[{
         RowBox[{"2", ";;", "10"}], ",", 
         RowBox[{"2", ";;", "10"}]}], "]"}], "]"}], "]"}], "==", "0"}], "&&", 
    RowBox[{
     RowBox[{"Matrix", "[", 
      RowBox[{"[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
         "1", ",", "3", ",", "4", ",", "5", ",", "6", ",", "7", ",", "8", ",",
           "9", ",", "10"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
         "1", ",", "3", ",", "4", ",", "5", ",", "6", ",", "7", ",", "8", ",",
           "9", ",", "10"}], "}"}]}], "]"}], "]"}], ">", "0"}], "&&", 
    RowBox[{"w", 
     StyleBox["\[Element]", "TR"], "Rationals"}]}], ",", 
   RowBox[{"{", 
    RowBox[{"w", ",", "u"}], "}"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.987817383121418*^9, 3.9878174262244797`*^9}, {
  3.9878174984601097`*^9, 3.9878174988208485`*^9}},
