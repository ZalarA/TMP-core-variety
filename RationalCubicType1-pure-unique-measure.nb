   3.9878170934654045`*^9}},ExpressionUUID->"5f391247-93e1-4047-8e57-\
47d0e433c412"],

Cell[CellGroupData[{

Cell["\<\
The corresponding univariate Hankel matrix has the basis \
h(T)^{-3},h(T)^{-3}T,h(T)^{-2},h(T)^{-2}T,h(T)^{-1},h(T)^{-1}T,1,T,T^2,T^3,T^\
4,T^5,T^6.\
\>", "Section",
 CellChangeTimes->{{3.9875956434420357`*^9, 3.987595649171936*^9}, {
  3.9875957067420845`*^9, 3.987595760931566*^9}, {3.987636231358671*^9, 
  3.9876362514016304`*^9}, {3.9876527688497314`*^9, 3.9876528120097275`*^9}, {
  3.9878171277348633`*^9, 
  3.9878171919514217`*^9}},ExpressionUUID->"5109579c-0e65-dc42-b662-\
ffdd1eb52bb1"],

